# Copy this file to .env and fill in real values. Never commit .env itself
# (it's gitignored) — these are just the variable NAMES the app expects.

# Supabase
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# Sentry error tracking (from sentry.io -> your project -> Settings ->
# Client Keys (DSN))
REACT_APP_SENTRY_DSN=

# PostHog product analytics (from app.posthog.com -> Settings -> Project
# API Key, and the Project API Host shown next to it)
REACT_APP_POSTHOG_KEY=
REACT_APP_POSTHOG_HOST=
